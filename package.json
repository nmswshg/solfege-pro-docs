{
  "name": "solfege-pro-docs",
  "version": "1.0.0",
  "description": "音楽練習アプリ「ソルフェージュPRO」の公式練習ガイドです。",
  "main": "drawer.js",
  "scripts": {
    "test": "playwright test",
    "test:nav": "playwright test tests/nav.spec.js",
    "test:report": "playwright show-report",
    "serve": "python3 -m http.server 8888",
    "build": "node tools/build-langs.js",
    "build:sitemap": "node tools/build-langs.js --sitemap-only",
    "check-css": "bash tools/check-responsive-css.sh",
    "check-layout": "playwright test tests/responsive-sweep.spec.js --project=desktop",
    "check-lang": "python3 tools/lang-purity-check.py",
    "test:visual": "playwright test tests/visual-regression.spec.js --project=desktop",
    "test:visual:update": "playwright test tests/visual-regression.spec.js --project=desktop --update-snapshots",
    "check-all": "npm run check-css && npm run check-layout && npm run test:visual"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nmswshg/solfege-pro-docs.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nmswshg/solfege-pro-docs/issues"
  },
  "homepage": "https://github.com/nmswshg/solfege-pro-docs#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}